# ## Dependencies ##
# Ignores the massive folder of installed packages.
# Anyone can recreate it by running `npm install`.
node_modules/

# ## Environment Variables ##
# Prevents committing secret keys, passwords, and API keys.
# This is the most important rule for security.
.env
.env.*
!.env.example

# ## Production Build ##
# Ignores the optimized build folders for your frontend app.
build/
dist/
.next/
.vercel/

# ## Log Files ##
# Ignores log files that can contain sensitive information.
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ## System Files ##
# Ignores operating system-specific files.
.DS_Store
Thumbs.db